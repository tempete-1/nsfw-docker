{
  "1": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "input.png"
    },
    "_meta": {"title": "Load Photo"}
  },
  "2": {
    "class_type": "DownloadAndLoadWanModel",
    "inputs": {
      "model": "Wan-AI/Wan2.1-I2V-14B-480P-Diffusers",
      "base_precision": "bf16",
      "quantization": "fp8_e4m3fn",
      "load_device": "offload"
    },
    "_meta": {"title": "Load Wan2.1 I2V 14B"}
  },
  "3": {
    "class_type": "DownloadAndLoadWanVideoVAE",
    "inputs": {
      "model": "Wan-AI/Wan2.1-I2V-14B-480P-Diffusers",
      "precision": "bf16"
    },
    "_meta": {"title": "Load Wan VAE"}
  },
  "4": {
    "class_type": "WanImageEncode",
    "inputs": {
      "vae": ["3", 0],
      "image": ["10", 0]
    },
    "_meta": {"title": "Encode Reference Image"}
  },
  "5": {
    "class_type": "WanClipTextEncode",
    "inputs": {
      "wan_model": ["2", 0],
      "prompt": "video prompt here"
    },
    "_meta": {"title": "positive prompt"}
  },
  "6": {
    "class_type": "WanClipTextEncode",
    "inputs": {
      "wan_model": ["2", 0],
      "prompt": "blurry, ugly, deformed, text, watermark, low quality, static, frozen, no motion"
    },
    "_meta": {"title": "negative prompt"}
  },
  "7": {
    "class_type": "WanI2VSampler",
    "inputs": {
      "wan_model": ["2", 0],
      "positive": ["5", 0],
      "negative": ["6", 0],
      "image_embeds": ["4", 0],
      "width": 832,
      "height": 480,
      "num_frames": 81,
      "steps": 30,
      "cfg": 5.0,
      "shift": 5.0,
      "seed": 42,
      "scheduler": "dpm_multistep",
      "guide_type": "i2v_ref_img",
      "teacache_thresh": 0.3
    },
    "_meta": {"title": "Wan I2V Sampler"}
  },
  "8": {
    "class_type": "WanVideoDecode",
    "inputs": {
      "vae": ["3", 0],
      "samples": ["7", 0],
      "enable_vae_tiling": true
    },
    "_meta": {"title": "Decode Video"}
  },
  "9": {
    "class_type": "VHS_VideoCombine",
    "inputs": {
      "images": ["8", 0],
      "frame_rate": 16,
      "loop_count": 0,
      "filename_prefix": "nolimits_video",
      "format": "video/h264-mp4",
      "save_output": true,
      "pingpong": false
    },
    "_meta": {"title": "Save Video MP4"}
  },
  "10": {
    "class_type": "ImageResizeKJ",
    "inputs": {
      "image": ["1", 0],
      "width": 832,
      "height": 480,
      "keep_proportion": true,
      "interpolation": "lanczos",
      "divisible_by": 16,
      "pad_or_crop": "pad"
    },
    "_meta": {"title": "Resize Input"}
  }
}
