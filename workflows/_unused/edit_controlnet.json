      "seed": 42,
      "steps": 20,
      "cfg": 3.5,
      "sampler_name": "euler",
      "scheduler": "normal",
      "denoise": 1.0
    },
    "_meta": {"title": "KSampler"}
  },
  "11": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["9", 0],
      "vae": ["4", 0]
