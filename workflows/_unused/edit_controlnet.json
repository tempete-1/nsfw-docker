  },
  "8": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "clip": ["3", 0],
      "text": "blurry, ugly, deformed, watermark, text, low quality, cartoon, bad anatomy, extra limbs"
    },
    "_meta": {"title": "negative prompt"}
  },
  "16": {
